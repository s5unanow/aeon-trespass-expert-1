# Auto-detect text files and normalize line endings
* text=auto

# Force LF for source files
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files
*.pdf binary
*.png binary
*.jpg binary
*.webp binary
*.woff binary
*.woff2 binary

# Generated files — mark for merge conflict awareness
packages/schemas/jsonschema/** linguist-generated=true
packages/schemas/ts/src/generated/** linguist-generated=true
