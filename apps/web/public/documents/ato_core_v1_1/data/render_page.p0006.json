    {
      "kind": "paragraph",
      "id": "p0006.b013",
      "children": [
        {
          "kind": "text",
          "text": "ИССЛЕДОВАНИЕ",
          "marks": []
        }
      ]
    },
    {
      "kind": "paragraph",
      "id": "p0006.b014",
