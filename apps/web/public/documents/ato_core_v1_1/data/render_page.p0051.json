        },
        {
          "kind": "text",
          "text": "do not ",
          "marks": []
        },
        {
          "kind": "text",
          "text": "resolve any other Responses if you criti-cally wound the BP card. ",
          "marks": []
        },
        {
          "kind": "text",
          "text": "Important:",
          "marks": []
        },
        {
