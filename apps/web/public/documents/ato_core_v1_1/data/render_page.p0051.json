        },
        {
          "kind": "text",
          "text": "Fail",
          "marks": []
        },
        {
          "kind": "text",
          "text": " to wound or regardless of your wound attempt, on ",
          "marks": []
        },
        {
          "kind": "text",
          "text": "Instinct",
          "marks": []
        },
        {
          "kind": "text",
          "text": ".",
