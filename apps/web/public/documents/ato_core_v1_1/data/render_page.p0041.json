    {
      "kind": "paragraph",
      "id": "p0041.b001",
      "children": [
        {
          "kind": "text",
          "text": "As a Primordial Response from a BP card, the Labyrinthauros tram-ples into the Board Edge. According to the rules, it continues to move along the edge, prioritizing movement that will initially lead it further away from the most Titans. Note that in the end this movement will still bring the Primordial closer to the Titan.",
          "marks": []
        }
      ]
    },
    {
      "kind": "heading",
      "id": "p0041.b002",
      "level": 2,
      "children": [
        {
          "kind": "text",
          "text": "1",
          "marks": []
        }
      ]
    },
    {
