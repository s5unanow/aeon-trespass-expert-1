      "level": 3,
      "children": [
        {
          "kind": "text",
          "text": "T5",
          "marks": []
        }
      ]
    },
    {
      "kind": "paragraph",
      "id": "p0015.b014",
      "children": [
        {
          "kind": "text",
          "text": "T6/00",
          "marks": []
        }
      ]
    },
    {
      "kind": "heading",
      "id": "p0015.b016",
      "level": 1,
      "children": [
        {
          "kind": "text",
          "text": "Странствие T",
          "marks": []
        }
      ]
    },
    {
      "kind": "heading",
